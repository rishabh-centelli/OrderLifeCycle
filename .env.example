APP_NAME="Agentic Order Cycle Management API"
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/order_lifecycle
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/order_lifecycle
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

JWT_SECRET_KEY=change-me-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
RATE_LIMIT=100/minute
LOG_LEVEL=INFO
